# WordPress Insights Chat Configuration
# Copy to .env and fill in as needed

# LLM API key (required)
OPENAI_API_KEY="sk-..."

# LLM model name (default: gpt-4o-mini)
# OPENAI_MODEL="gpt-4o-mini"

# Custom API base URL (for proxies, OpenRouter, local LLMs, etc.)
# OPENAI_BASE_URL="https://api.openai.com/v1"
